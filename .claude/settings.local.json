{
  "permissions": {
    "allow": [
      "Bash(kubectl config current-context)",
      "Bash(kubectl get nodes*)",
      "Bash(kubectl get pods*)",
      "Bash(kubectl get pdb*)",
      "Bash(kubectl get events*)",
      "Bash(kubectl get nodeclaims*)",
      "Bash(kubectl logs*)",
      "Bash(helm list*)",
      "Bash(aws eks describe-cluster*)",
      "Bash(aws eks list-addons*)",
      "Bash(aws eks describe-addon*)",
      "Bash(aws ssm get-parameters-by-path*)",
      "Bash(terraform plan*)",
      "Bash(terraform apply*)",
      "mcp__awslabs_eks-mcp-server__get_eks_insights",
      "mcp__awslabs_eks-mcp-server__list_k8s_resources",
      "Bash(aws eks:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "awslabs.eks-mcp-server"
  ]
}
